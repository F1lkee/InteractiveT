<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Современная светлая тема -->
    <Color x:Key="LightBackgroundColor">#F5F7FA</Color>
    <Color x:Key="LightCardColor">#FFFFFF</Color>
    <Color x:Key="LightAccentColor">#6366F1</Color>
    <Color x:Key="LightAccentHoverColor">#4F46E5</Color>
    <Color x:Key="LightSuccessColor">#10B981</Color>
    <Color x:Key="LightErrorColor">#EF4444</Color>
    <Color x:Key="LightWarningColor">#F59E0B</Color>
    <Color x:Key="LightInfoColor">#3B82F6</Color>
    <Color x:Key="LightTextPrimaryColor">#1F2937</Color>
    <Color x:Key="LightTextSecondaryColor">#6B7280</Color>
    <Color x:Key="LightTextTertiaryColor">#9CA3AF</Color>
    <Color x:Key="LightBorderColor">#E5E7EB</Color>
    <Color x:Key="LightShadowColor">#000000</Color>

    <!-- Современная тёмная тема -->
    <Color x:Key="DarkBackgroundColor">#0F172A</Color>
    <Color x:Key="DarkSurfaceColor">#1E293B</Color>
    <Color x:Key="DarkCardColor">#334155</Color>
    <Color x:Key="DarkAccentColor">#818CF8</Color>
    <Color x:Key="DarkAccentHoverColor">#6366F1</Color>
    <Color x:Key="DarkSuccessColor">#34D399</Color>
    <Color x:Key="DarkErrorColor">#F87171</Color>
    <Color x:Key="DarkWarningColor">#FBBF24</Color>
    <Color x:Key="DarkInfoColor">#60A5FA</Color>
    <Color x:Key="DarkTextPrimaryColor">#F1F5F9</Color>
    <Color x:Key="DarkTextSecondaryColor">#94A3B8</Color>
    <Color x:Key="DarkTextTertiaryColor">#64748B</Color>
    <Color x:Key="DarkBorderColor">#475569</Color>
    <Color x:Key="DarkShadowColor">#000000</Color>

    <!-- Градиентные кисти -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#6366F1" Offset="0"/>
        <GradientStop Color="#8B5CF6" Offset="0.5"/>
        <GradientStop Color="#EC4899" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SuccessGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#10B981" Offset="0"/>
        <GradientStop Color="#34D399" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="InfoGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#3B82F6" Offset="0"/>
        <GradientStop Color="#60A5FA" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WarningGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F59E0B" Offset="0"/>
        <GradientStop Color="#FBBF24" Offset="1"/>
    </LinearGradientBrush>

    <!-- Brushes светлая тема -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource LightBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource LightCardColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource LightAccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource LightAccentHoverColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource LightSuccessColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource LightErrorColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource LightWarningColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource LightInfoColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource LightTextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource LightTextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource LightTextTertiaryColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource LightBorderColor}"/>
    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource LightShadowColor}" Opacity="0.1"/>

    <!-- Тёмная тема Brushes -->
    <SolidColorBrush x:Key="DarkBackgroundBrush" Color="{StaticResource DarkBackgroundColor}"/>
    <SolidColorBrush x:Key="DarkSurfaceBrush" Color="{StaticResource DarkSurfaceColor}"/>
    <SolidColorBrush x:Key="DarkCardBrush" Color="{StaticResource DarkCardColor}"/>
    <SolidColorBrush x:Key="DarkAccentBrush" Color="{StaticResource DarkAccentColor}"/>
    <SolidColorBrush x:Key="DarkAccentHoverBrush" Color="{StaticResource DarkAccentHoverColor}"/>
    <SolidColorBrush x:Key="DarkSuccessBrush" Color="{StaticResource DarkSuccessColor}"/>
    <SolidColorBrush x:Key="DarkErrorBrush" Color="{StaticResource DarkErrorColor}"/>
    <SolidColorBrush x:Key="DarkWarningBrush" Color="{StaticResource DarkWarningColor}"/>
    <SolidColorBrush x:Key="DarkInfoBrush" Color="{StaticResource DarkInfoColor}"/>
    <SolidColorBrush x:Key="DarkTextPrimaryBrush" Color="{StaticResource DarkTextPrimaryColor}"/>
    <SolidColorBrush x:Key="DarkTextSecondaryBrush" Color="{StaticResource DarkTextSecondaryColor}"/>
    <SolidColorBrush x:Key="DarkTextTertiaryBrush" Color="{StaticResource DarkTextTertiaryColor}"/>
    <SolidColorBrush x:Key="DarkBorderBrush" Color="{StaticResource DarkBorderColor}"/>
    <SolidColorBrush x:Key="DarkShadowBrush" Color="{StaticResource DarkShadowColor}" Opacity="0.3"/>

</ResourceDictionary>