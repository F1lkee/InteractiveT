<Window x:Class="InteractiveTWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InteractiveTWPF"
        mc:Ignorable="d"
            Title="Система тестирования - Вход" 
    Height="600" Width="450"
    WindowStartupLocation="CenterScreen"
    Background="{StaticResource BackgroundBrush}"
    ResizeMode="NoResize">

    <Grid>
        <!-- Декоративный фон с градиентом -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F5F7FA" Offset="0"/>
                <GradientStop Color="#E0E7FF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Style="{StaticResource CardStyle}" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center"
            Width="360">
            <StackPanel>
                <!-- Логотип / Иконка -->
                <Border Background="{StaticResource AccentGradientBrush}"
                        CornerRadius="50"
                        Width="80"
                        Height="80"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20"
                        Effect="{StaticResource MediumShadow}">
                    <TextBlock Text="📝" 
                              FontSize="40" 
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Добро пожаловать!" 
                      FontSize="26" 
                      FontWeight="Bold"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,5"/>
                
                <TextBlock Text="Войдите для продолжения" 
                      FontSize="14"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,30"/>

                <TextBlock Text="Логин" 
                      Foreground="{StaticResource TextSecondaryBrush}"
                      FontWeight="Medium"
                      Margin="0,0,0,8"/>
                <TextBox x:Name="LoginTextBox" 
                    Style="{StaticResource ModernTextBoxStyle}"
                    Margin="0,0,0,20"/>

                <TextBlock Text="Пароль" 
                      Foreground="{StaticResource TextSecondaryBrush}"
                      FontWeight="Medium"
                      Margin="0,0,0,8"/>
                <PasswordBox x:Name="PasswordBox"
                        Style="{StaticResource ModernPasswordBoxStyle}"
                        Margin="0,0,0,25"/>

                <Button x:Name="LoginButton"
                    Content="Войти в систему"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="LoginButton_Click"
                    Height="50"
                    FontSize="15"/>

                <TextBlock x:Name="ErrorTextBlock"
                      Foreground="{StaticResource ErrorBrush}"
                      TextWrapping="Wrap"
                      Margin="0,15,0,0"
                      Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
