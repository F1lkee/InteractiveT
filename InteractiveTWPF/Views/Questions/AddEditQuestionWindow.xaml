<Window x:Class="InteractiveTWPF.AddEditQuestionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Вопрос"
        Height="650" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Text="Новый вопрос"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- Текст вопроса -->
                <TextBlock Text="Текст вопроса"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="QuestionTextTextBox"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Margin="0,0,0,10"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Height="60"/>

                <!-- Тип вопроса -->
                <TextBlock Text="Тип вопроса"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <ComboBox x:Name="QuestionTypeComboBox"
                          SelectedIndex="0"
                          Margin="0,0,0,10"
                          Padding="12,8"
                          FontSize="14">
                    <ComboBoxItem Content="Один правильный ответ" Tag="SingleChoice"/>
                    <ComboBoxItem Content="Несколько правильных ответов" Tag="MultipleChoice"/>
                    <ComboBoxItem Content="Текстовый ответ" Tag="TextInput"/>
                </ComboBox>

                <!-- Баллы -->
                <TextBlock Text="Баллы за вопрос"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="PointsTextBox"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Margin="0,0,0,10"
                         Text="1"/>

                <!-- Объяснение -->
                <TextBlock Text="Объяснение (показывается после ответа)"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="ExplanationTextBox"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Margin="0,0,0,10"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Height="50"/>

                <!-- Картинка -->
                <Border Style="{StaticResource CardStyle}" Padding="15">
                    <StackPanel>
                        <TextBlock Text="📷 Картинка к вопросу"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,10"/>
                        <Image x:Name="QuestionImage"
                               MaxHeight="150"
                               Stretch="Uniform"
                               Margin="0,0,0,10"
                               Visibility="Collapsed"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Выбрать файл..."
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="BrowseImageButton_Click"
                                    Width="150"
                                    Margin="0,0,10,0"/>
                            <Button Content="Удалить картинку"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="RemoveImageButton_Click"
                                    Width="150"
                                    Background="{StaticResource ErrorBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Варианты ответов -->
                <TextBlock Text="Варианты ответов"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,10,0,10"/>

                <ItemsControl x:Name="AnswersItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox x:Name="IsCorrectCheckBox"
                                              IsChecked="{Binding IsCorrect}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"
                                              ToolTip="Правильный ответ"/>

                                    <TextBox Grid.Column="1"
                                             Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBoxStyle}"
                                             Margin="0,0,8,0"
                                             ToolTip="Текст ответа"/>

                                    <Button Grid.Column="2"
                                            Content="✕"
                                            Click="RemoveAnswerButton_Click"
                                            Background="{StaticResource ErrorBrush}"
                                            Foreground="White"
                                            Padding="8,4"
                                            BorderThickness="0"
                                            Cursor="Hand"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="+ Добавить вариант ответа"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="AddAnswerButton_Click"
                        Width="200"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,10"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="Сохранить"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="130"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click"/>
            <Button Content="Отмена"
                    Width="130"
                    Background="{StaticResource TextSecondaryBrush}"
                    Foreground="White"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
