<Window x:Class="InteractiveTWPF.EditTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Редактирование теста"
        Height="820" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/Colors.xaml"/>
                <ResourceDictionary Source="../../Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Background="{StaticResource AccentBrush}" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="TestTitleTextBlock"
                               Text="Название теста"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock x:Name="TestInfoTextBlock"
                               Text="Информация"
                               FontSize="14"
                               Foreground="#DDFFFFFF"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="💾 Сохранить"
                            Click="SaveButton_Click"
                            Background="#33FFFFFF"
                            Foreground="White"
                            Padding="15,8"
                            Margin="0,0,10,0"
                            BorderThickness="0"/>
                    <Button Content="Закрыть"
                            Click="CloseButton_Click"
                            Background="#33FFFFFF"
                            Foreground="White"
                            Padding="15,8"
                            BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область -->
        <TabControl Grid.Row="1" Margin="10,10,10,0">
            <!-- Вопросы -->
            <TabItem Header="❓ Вопросы">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="+ Добавить вопрос"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="AddQuestionButton_Click"
                                Width="170"/>
                        <Button Content="✏️ Изменить"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="EditQuestionButton_Click"
                                Margin="10,0,0,0"
                                Background="{StaticResource WarningBrush}"
                                Width="120"/>
                        <Button Content="🗑️ Удалить"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="DeleteQuestionButton_Click"
                                Margin="10,0,0,0"
                                Background="{StaticResource ErrorBrush}"
                                Width="100"/>
                    </StackPanel>

                    <DataGrid x:Name="QuestionsDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="{StaticResource CardBrush}"
                              BorderThickness="0"
                              RowBackground="{StaticResource CardBrush}"
                              AlternatingRowBackground="#FFF8F9FA"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding OrderIndex}" Width="Auto"/>
                            <DataGridTextColumn Header="Вопрос" Binding="{Binding Text}" Width="*"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="Auto"/>
                            <DataGridTextColumn Header="Баллы" Binding="{Binding Points}" Width="Auto"/>
                            <DataGridTextColumn Header="Ответов" Binding="{Binding Answers.Count}" Width="Auto"/>
                            <DataGridTemplateColumn Header="Картинка" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HasImage}" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Настройки теста -->
            <TabItem Header="⚙️ Настройки">
                <ScrollViewer Margin="10">
                    <StackPanel>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Название"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,5"/>
                                <TextBox x:Name="TitleTextBox"
                                         Style="{StaticResource ModernTextBoxStyle}"
                                         Margin="0,0,0,15"/>

                                <TextBlock Text="Описание"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,5"/>
                                <TextBox x:Name="DescriptionTextBox"
                                         Style="{StaticResource ModernTextBoxStyle}"
                                         Margin="0,0,0,15"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         Height="60"/>

                                <TextBlock Text="Предмет"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,5"/>
                                <ComboBox x:Name="SubjectComboBox"
                                          Margin="0,0,0,15"
                                          Padding="12,8"
                                          FontSize="14"
                                          DisplayMemberPath="Name"/>

                                <TextBlock Text="Класс (необязательно)"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,5"/>
                                <ComboBox x:Name="ClassComboBox"
                                          Margin="0,0,0,15"
                                          Padding="12,8"
                                          FontSize="14"
                                          DisplayMemberPath="Name"/>

                                <TextBlock Text="Лимит времени (секунды, 0 = без лимита)"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,5"/>
                                <TextBox x:Name="TimeLimitTextBox"
                                         Style="{StaticResource ModernTextBoxStyle}"
                                         Margin="0,0,0,15"/>

                                <CheckBox x:Name="ShuffleQuestionsCheckBox"
                                          Content="Перемешивать вопросы"
                                          FontSize="14"
                                          Margin="0,0,0,5"/>

                                <CheckBox x:Name="ShuffleAnswersCheckBox"
                                          Content="Перемешивать ответы"
                                          FontSize="14"
                                          Margin="0,0,0,5"/>

                                <CheckBox x:Name="ShowResultsCheckBox"
                                          Content="Показывать результаты сразу"
                                          FontSize="14"
                                          Margin="0,0,0,5"/>

                                <CheckBox x:Name="IsPublishedCheckBox"
                                          Content="Опубликован"
                                          FontSize="14"
                                          Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Статус-бар -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBrush}"
                Padding="15,8"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0">
            <TextBlock x:Name="StatusTextBlock"
                       Text="Готово"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </Border>
    </Grid>
</Window>
