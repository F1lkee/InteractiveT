<Window x:Class="InteractiveTWPF.CreateTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Создание теста"
        Height="620" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/Colors.xaml"/>
                <ResourceDictionary Source="../../Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <ScrollViewer>
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Новый тест"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,20"/>

            <StackPanel Grid.Row="1">
                <TextBlock Text="Название теста"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="TitleTextBox"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Margin="0,0,0,15"/>

                <TextBlock Text="Описание"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="DescriptionTextBox"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Margin="0,0,0,15"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Height="60"/>

                <TextBlock Text="Предмет"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <ComboBox x:Name="SubjectComboBox"
                          Margin="0,0,0,15"
                          Padding="12,8"
                          FontSize="14"
                          DisplayMemberPath="Name"
                          SelectionChanged="SubjectComboBox_SelectionChanged"/>

                <TextBlock Text="Класс (необязательно)"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <ComboBox x:Name="ClassComboBox"
                          Margin="0,0,0,15"
                          Padding="12,8"
                          FontSize="14"
                          DisplayMemberPath="Name"
                          ToolTip="Выберите класс для которого предназначен тест"/>

                <TextBlock Text="Лимит времени (секунды, 0 = без лимита)"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="TimeLimitTextBox"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Margin="0,0,0,15"
                         Text="900"/>

                <CheckBox x:Name="ShuffleQuestionsCheckBox"
                          Content="Перемешивать вопросы"
                          FontSize="14"
                          Margin="0,0,0,5"/>

                <CheckBox x:Name="ShuffleAnswersCheckBox"
                          Content="Перемешивать ответы"
                          FontSize="14"
                          Margin="0,0,0,5"/>

                <CheckBox x:Name="IsPublishedCheckBox"
                          Content="Опубликовать сразу"
                          FontSize="14"
                          IsChecked="True"
                          Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="Создать"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="130"
                        Margin="0,0,10,0"
                        Click="CreateButton_Click"/>
                <Button Content="Отмена"
                        Width="130"
                        Background="{StaticResource TextSecondaryBrush}"
                        Foreground="White"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
