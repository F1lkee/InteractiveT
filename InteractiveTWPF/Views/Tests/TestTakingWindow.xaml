<Window x:Class="InteractiveTWPF.TestTakingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Прохождение теста"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- Основная область (вопрос) -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Шапка с таймером и прогрессом -->
            <Border Background="{StaticResource CardBrush}" Padding="25,20" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="TestTitleTextBlock"
                                   Text="Название теста"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ProgressBar x:Name="ProgressBar"
                                     Height="6"
                                     Margin="0,10,0,0"
                                     Value="0"
                                     Maximum="100"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="#E0E0E0"
                                     BorderThickness="0"/>
                        <TextBlock x:Name="ProgressTextBlock"
                                   Text="Вопрос 1 из 10"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            x:Name="TimerBorder"
                            Background="{StaticResource AccentBrush}"
                            CornerRadius="25"
                            Padding="20,10">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Осталось времени"
                                       FontSize="11"
                                       Foreground="#DDFFFFFF"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,3"/>
                            <TextBlock x:Name="TimerTextBlock"
                                       Text="15:00"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Область вопроса -->
            <ScrollViewer Grid.Row="1" Margin="40,30">
                <StackPanel x:Name="QuestionPanel" MaxWidth="800">
                    <!-- Номер и текст вопроса -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock x:Name="QuestionNumberTextBlock"
                                       Text="Вопрос 1"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,0,0,10"/>
                            <TextBlock x:Name="QuestionTextBlock"
                                       Text="Текст вопроса здесь..."
                                       FontSize="20"
                                       TextWrapping="Wrap"
                                       LineHeight="30"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Изображение (если есть) -->
                    <Border x:Name="QuestionImageBorder"
                            Style="{StaticResource CardStyle}"
                            Margin="0,0,0,20"
                            Visibility="Collapsed">
                        <Image x:Name="QuestionImage"
                               MaxHeight="400"
                               Stretch="Uniform"/>
                    </Border>

                    <!-- Варианты ответа -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Выберите ответ:"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,15"/>
                            <StackPanel x:Name="AnswersPanel"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Навигация -->
            <Border Grid.Row="2"
                    Background="{StaticResource CardBrush}"
                    Padding="25,20"
                    BorderThickness="0,1,0,0"
                    BorderBrush="#E0E0E0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="PrevButton"
                            Content="← Назад"
                            Click="PrevButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="{StaticResource TextSecondaryBrush}"
                            Width="130"
                            Height="45"
                            FontSize="14"/>

                    <Button Grid.Column="2"
                            x:Name="NextButton"
                            Content="Далее →"
                            Click="NextButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="130"
                            Height="45"
                            FontSize="14"/>
                </Grid>
            </Border>

            <!-- Экран результатов (скрыт по умолчанию) -->
            <Grid x:Name="ResultsOverlay"
                  Grid.RowSpan="3"
                  Background="{StaticResource BackgroundBrush}"
                  Visibility="Collapsed">
                <ScrollViewer>
                    <StackPanel MaxWidth="600" Margin="40">
                        <TextBlock Text="Результаты теста"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,30"/>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="ResultScoreTextBlock"
                                           Text="85%"
                                           FontSize="64"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="ResultDetailsTextBlock"
                                           Text="17 из 20 вопросов"
                                           FontSize="18"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock x:Name="ResultPassTextBlock"
                                           Text="Тест сдан!"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,10"/>
                                <TextBlock x:Name="ResultTimeTextBlock"
                                           Text="Затраченное время: 12 мин 35 сек"
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Content="Закрыть"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="CloseResultsButton_Click"
                                Width="200"
                                Height="45"
                                FontSize="16"
                                HorizontalAlignment="Center"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Боковая панель навигации -->
        <Border Grid.Column="1"
                Background="{StaticResource CardBrush}"
                BorderThickness="1,0,0,0"
                BorderBrush="#E0E0E0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Навигация"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="20,20,20,15"/>

                <ScrollViewer Grid.Row="1" Margin="15,0,15,15">
                    <WrapPanel x:Name="QuestionNavigationPanel"
                               Orientation="Horizontal"
                               HorizontalAlignment="Center"/>
                </ScrollViewer>

                <!-- Легенда -->
                <Border Grid.Row="2"
                        Margin="15,0,15,20"
                        Padding="15"
                        Background="#F8F9FA"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Легенда:"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,8"/>

                        <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                            <Border Width="24" Height="24" Background="{StaticResource AccentBrush}" CornerRadius="4" Margin="0,0,8,0"/>
                            <TextBlock Text="Текущий" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                            <Border Width="24" Height="24" Background="#4CAF50" CornerRadius="4" Margin="0,0,8,0"/>
                            <TextBlock Text="Отвечен" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                            <Border Width="24" Height="24" Background="#E0E0E0" CornerRadius="4" Margin="0,0,8,0"/>
                            <TextBlock Text="Не отвечен" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Кнопка завершения -->
                <Button Content="✓ Завершить тест"
                        Grid.Row="3"
                        Margin="15,0,15,20"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="#4CAF50"
                        Height="45"
                        FontSize="14"
                        Click="FinishButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
