<Window x:Class="InteractiveTWPF.DeputyPrincipalDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InteractiveTWPF"
        xmlns:converters="clr-namespace:InteractiveTWPF.Converters"
        mc:Ignorable="d"
        Title="Кабинет завуча"
        Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/Colors.xaml"/>
                <ResourceDictionary Source="../../Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:ScoreDisplayConverter x:Key="ScoreDisplayConverter"/>
            <converters:StatusDisplayConverter x:Key="StatusDisplayConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Background="{StaticResource WarningBrush}" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="WelcomeTextBlock"
                               Text="Кабинет завуча"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock x:Name="InfoTextBlock"
                               Text="Мониторинг и аналитика"
                               FontSize="14"
                               Foreground="#DDFFFFFF"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Выйти"
                        Click="LogoutButton_Click"
                        Background="#33FFFFFF"
                        Foreground="White"
                        Padding="20,10"
                        BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- Вкладки -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="10,10,10,0">
            <!-- Общая аналитика -->
            <TabItem Header="📈 Аналитика">
                <ScrollViewer Margin="15">
                    <StackPanel>
                        <TextBlock Text="Обзор успеваемости"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,20"/>

                        <!-- Карточки статистики -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource CardStyle}" Grid.Column="0" Margin="5">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📊" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="AvgScoreTextBlock"
                                               Text="0%"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Средний балл"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Grid.Column="1" Margin="5">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="✅" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="PassRateTextBlock"
                                               Text="0%"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource SuccessBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Сдаваемость"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Grid.Column="2" Margin="5">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📝" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotalTestsTextBlock"
                                               Text="0"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource WarningBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Тестов пройдено"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Лучшие ученики -->
                        <TextBlock Text="🏆 Лучшие ученики"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,20,0,10"/>

                        <DataGrid x:Name="TopStudentsDataGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Background="{StaticResource CardBrush}"
                                  BorderThickness="0"
                                  RowBackground="{StaticResource CardBrush}"
                                  AlternatingRowBackground="#FFF8F9FA"
                                  GridLinesVisibility="Horizontal"
                                  MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ученик" Binding="{Binding FullName}" Width="*"/>
                                <DataGridTextColumn Header="Попыток" Binding="{Binding AttemptCount}" Width="Auto"/>
                                <DataGridTextColumn Header="Средний балл" Binding="{Binding AvgScoreDisplay}" Width="Auto"/>
                                <DataGridTextColumn Header="Сдано" Binding="{Binding PassedCount}" Width="Auto"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Тесты с низкой сдаваемостью -->
                        <TextBlock Text="⚠️ Тесты с низкой сдаваемостью"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ErrorBrush}"
                                   Margin="0,20,0,10"/>

                        <DataGrid x:Name="LowPassRateTestsDataGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Background="{StaticResource CardBrush}"
                                  BorderThickness="0"
                                  RowBackground="{StaticResource CardBrush}"
                                  AlternatingRowBackground="#FFF8F9FA"
                                  GridLinesVisibility="Horizontal"
                                  MaxHeight="250">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Тест" Binding="{Binding Title}" Width="*"/>
                                <DataGridTextColumn Header="Предмет" Binding="{Binding Subject.Name}" Width="Auto"/>
                                <DataGridTextColumn Header="Попыток" Binding="{Binding AttemptCount}" Width="Auto"/>
                                <DataGridTextColumn Header="% Сдачи" Binding="{Binding PassRateDisplay}" Width="Auto"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Результаты учеников -->
            <TabItem Header="👨‍🎓 Результаты учеников">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Все результаты тестирования"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Button Content="🔄 Обновить"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="RefreshResultsButton_Click"
                                Margin="15,0,0,0"
                                Background="#7F8C8D"
                                Width="120"/>
                    </StackPanel>

                    <DataGrid x:Name="AllResultsDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="{StaticResource CardBrush}"
                              BorderThickness="0"
                              RowBackground="{StaticResource CardBrush}"
                              AlternatingRowBackground="#FFF8F9FA"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ученик" Binding="{Binding User.FullName}" Width="*"/>
                            <DataGridTextColumn Header="Тест" Binding="{Binding Test.Title}" Width="*"/>
                            <DataGridTextColumn Header="Предмет" Binding="{Binding Test.Subject.Name}" Width="Auto"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding StartedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="Auto"/>
                            <DataGridTextColumn Header="Результат" Binding="{Binding Converter={StaticResource ScoreDisplayConverter}}" Width="Auto"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Converter={StaticResource StatusDisplayConverter}}" Width="Auto"/>
                            <DataGridTextColumn Header="Время" Binding="{Binding TimeSpent, StringFormat={}{0:c}}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Учителя -->
            <TabItem Header="👨‍🏫 Учителя">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Список учителей и их активность"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <DataGrid x:Name="TeachersDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="{StaticResource CardBrush}"
                              BorderThickness="0"
                              RowBackground="{StaticResource CardBrush}"
                              AlternatingRowBackground="#FFF8F9FA"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="Auto"/>
                            <DataGridTextColumn Header="Тестов создано" Binding="{Binding CreatedTests.Count}" Width="Auto"/>
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Классы -->
            <TabItem Header="🏫 Классы">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Учебные классы и их заполненность"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <DataGrid x:Name="ClassesDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="{StaticResource CardBrush}"
                              BorderThickness="0"
                              RowBackground="{StaticResource CardBrush}"
                              AlternatingRowBackground="#FFF8F9FA"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Класс" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Уровень" Binding="{Binding GradeLevel}" Width="Auto"/>
                            <DataGridTextColumn Header="Учеников" Binding="{Binding UserClasses.Count}" Width="Auto"/>
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
