<Window x:Class="InteractiveTWPF.AdminDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InteractiveTWPF"
        xmlns:converters="clr-namespace:InteractiveTWPF.Converters"
        mc:Ignorable="d"
        Title="Панель администратора"
        Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="../../Resources/Colors.xaml"/>
            <ResourceDictionary Source="../../Resources/Styles.xaml"/>
        </ResourceDictionary.MergedDictionaries>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка с градиентом -->
        <Border Padding="20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#8B5CF6" Offset="0.5"/>
                    <GradientStop Color="#EC4899" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="WelcomeTextBlock"
                               Text="Панель администратора"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock x:Name="StatsTextBlock"
                               Text="Загрузка статистики..."
                               FontSize="14"
                               Foreground="#E0E7FF"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="🚪 Выйти"
                        Click="LogoutButton_Click"
                        Background="#FFFFFF20"
                        Foreground="White"
                        Padding="20,12"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#FFFFFF20"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFFFFF40"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Вкладки с современным стилем -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="20,20,20,0" Style="{StaticResource ModernTabControlStyle}">
            <!-- Пользователи -->
            <TabItem Header="👥 Пользователи" Style="{StaticResource ModernTabItemStyle}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="➕ Добавить пользователя"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="AddUserButton_Click"
                                Width="200"/>
                        <Button Content="🔄 Обновить"
                                Click="RefreshUsersButton_Click"
                                Margin="10,0,0,0"
                                Background="#7F8C8D"
                                Width="130"
                                Foreground="White"
                                Padding="16,12"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="14"
                                FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="10"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Opacity" Value="0.9"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <DataGrid x:Name="UsersDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Style="{StaticResource ModernDataGridStyle}"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="Auto"/>
                            <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="Auto"/>
                            <DataGridTextColumn Header="Активен" Binding="{Binding IsActive}" Width="Auto"/>
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="Auto"/>
                            <DataGridTemplateColumn Header="Действия" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="✏️"
                                                    Click="EditUserButton_Click"
                                                    Margin="5,0"
                                                    Style="{StaticResource IconButtonStyle}"/>
                                            <Button Content="🗑️"
                                                    Click="DeleteUserButton_Click"
                                                    Margin="5,0"
                                                    Style="{StaticResource IconButtonStyle}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Предметы -->
            <TabItem Header="📚 Предметы" Style="{StaticResource ModernTabItemStyle}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="➕ Добавить предмет"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="AddSubjectButton_Click"
                                Width="200"/>
                    </StackPanel>

                    <DataGrid x:Name="SubjectsDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Style="{StaticResource ModernDataGridStyle}"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Тестов" Binding="{Binding Tests.Count}" Width="Auto"/>
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Классы -->
            <TabItem Header="🏫 Классы" Style="{StaticResource ModernTabItemStyle}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="➕ Добавить класс"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="AddClassButton_Click"
                                Width="180"/>
                    </StackPanel>

                    <DataGrid x:Name="ClassesDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Style="{StaticResource ModernDataGridStyle}"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Уровень" Binding="{Binding GradeLevel}" Width="Auto"/>
                            <DataGridTextColumn Header="Учеников" Binding="{Binding UserClasses.Count}" Width="Auto"/>
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Статистика системы -->
            <TabItem Header="📊 Статистика" Style="{StaticResource ModernTabItemStyle}">
                <ScrollViewer Margin="10">
                    <StackPanel>
                        <TextBlock Text="Общая статистика системы"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource StatCardStyle}" Grid.Column="0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="👥" FontSize="40" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotalUsersTextBlock"
                                               Text="0"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,5"/>
                                    <TextBlock Text="Пользователей"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource StatCardStyle}" Grid.Column="1">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📝" FontSize="40" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotalTestsTextBlock"
                                               Text="0"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource SuccessBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,5"/>
                                    <TextBlock Text="Тестов"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource StatCardStyle}" Grid.Column="2">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📚" FontSize="40" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotalSubjectsTextBlock"
                                               Text="0"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource WarningBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,5"/>
                                    <TextBlock Text="Предметов"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource StatCardStyle}" Grid.Column="3">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="✅" FontSize="40" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotalAttemptsTextBlock"
                                               Text="0"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource InfoBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,5"/>
                                    <TextBlock Text="Попыток"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Text="Распределение по ролям"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,30,0,15"/>

                        <ItemsControl x:Name="RoleStatsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding RoleName}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Count}"
                                                       FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       Grid.Column="1"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
