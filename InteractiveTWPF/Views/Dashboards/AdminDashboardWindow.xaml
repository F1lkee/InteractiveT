<Window x:Class="InteractiveTWPF.AdminDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InteractiveTWPF"
        xmlns:converters="clr-namespace:InteractiveTWPF.Converters"
        mc:Ignorable="d"
        Title="Панель администратора"
        Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Background="{StaticResource ErrorBrush}" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="WelcomeTextBlock"
                               Text="Панель администратора"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock x:Name="StatsTextBlock"
                               Text="Загрузка статистики..."
                               FontSize="14"
                               Foreground="#DDFFFFFF"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Выйти"
                        Click="LogoutButton_Click"
                        Background="#33FFFFFF"
                        Foreground="White"
                        Padding="20,10"
                        BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- Вкладки -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="10,10,10,0">
            <!-- Пользователи -->
            <TabItem Header="👥 Пользователи">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="+ Добавить пользователя"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="AddUserButton_Click"
                                Width="180"/>
                        <Button Content="🔄 Обновить"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="RefreshUsersButton_Click"
                                Margin="10,0,0,0"
                                Background="#7F8C8D"
                                Width="120"/>
                    </StackPanel>

                    <DataGrid x:Name="UsersDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="{StaticResource CardBrush}"
                              BorderThickness="0"
                              RowBackground="{StaticResource CardBrush}"
                              AlternatingRowBackground="#FFF8F9FA"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="Auto"/>
                            <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="Auto"/>
                            <DataGridTextColumn Header="Активен" Binding="{Binding IsActive}" Width="Auto"/>
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="Auto"/>
                            <DataGridTemplateColumn Header="Действия" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="✏️"
                                                    Click="EditUserButton_Click"
                                                    Margin="5,0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Foreground="{StaticResource AccentBrush}"
                                                    Cursor="Hand"/>
                                            <Button Content="🗑️"
                                                    Click="DeleteUserButton_Click"
                                                    Margin="5,0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Foreground="{StaticResource ErrorBrush}"
                                                    Cursor="Hand"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Предметы -->
            <TabItem Header="📚 Предметы">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="+ Добавить предмет"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="AddSubjectButton_Click"
                                Width="180"/>
                    </StackPanel>

                    <DataGrid x:Name="SubjectsDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="{StaticResource CardBrush}"
                              BorderThickness="0"
                              RowBackground="{StaticResource CardBrush}"
                              AlternatingRowBackground="#FFF8F9FA"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Тестов" Binding="{Binding Tests.Count}" Width="Auto"/>
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Классы -->
            <TabItem Header="🏫 Классы">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="+ Добавить класс"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="AddClassButton_Click"
                                Width="170"/>
                    </StackPanel>

                    <DataGrid x:Name="ClassesDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="{StaticResource CardBrush}"
                              BorderThickness="0"
                              RowBackground="{StaticResource CardBrush}"
                              AlternatingRowBackground="#FFF8F9FA"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Уровень" Binding="{Binding GradeLevel}" Width="Auto"/>
                            <DataGridTextColumn Header="Учеников" Binding="{Binding UserClasses.Count}" Width="Auto"/>
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Статистика системы -->
            <TabItem Header="📊 Статистика">
                <ScrollViewer Margin="15">
                    <StackPanel>
                        <TextBlock Text="Общая статистика системы"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource CardStyle}" Grid.Column="0" Margin="5">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="👥" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotalUsersTextBlock"
                                               Text="0"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Пользователей"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Grid.Column="1" Margin="5">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📝" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotalTestsTextBlock"
                                               Text="0"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource SuccessBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Тестов"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Grid.Column="2" Margin="5">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📚" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotalSubjectsTextBlock"
                                               Text="0"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource WarningBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Предметов"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Grid.Column="3" Margin="5">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="✅" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotalAttemptsTextBlock"
                                               Text="0"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Попыток"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Text="Распределение по ролям"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,20,0,10"/>

                        <ItemsControl x:Name="RoleStatsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding RoleName}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Count}"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       Grid.Column="1"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
