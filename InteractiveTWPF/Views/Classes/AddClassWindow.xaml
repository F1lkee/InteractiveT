<Window x:Class="InteractiveTWPF.AddClassWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Добавление класса"
        Height="320" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="../../Resources/Colors.xaml"/>
            <ResourceDictionary Source="../../Resources/Styles.xaml"/>
        </ResourceDictionary.MergedDictionaries>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Новый класс"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Название класса"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="ClassNameTextBox"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Margin="0,0,0,15"
                     ToolTip="Например: 11А, 9Б"/>

            <TextBlock Text="Уровень (класс)"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="GradeLevelTextBox"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Margin="0,0,0,15"
                     Text="1"
                     ToolTip="Числовой уровень класса (1-11)"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Добавить"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="130"
                    Margin="0,0,10,0"
                    Click="AddButton_Click"/>
            <Button Content="Отмена"
                    Width="130"
                    Background="{StaticResource TextSecondaryBrush}"
                    Foreground="White"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
