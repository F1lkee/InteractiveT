<UserControl x:Class="InteractiveTWPF.AiChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:InteractiveTWPF"
             mc:Ignorable="d"
             d:DesignWidth="420" d:DesignHeight="700">
    
    <UserControl.Resources>
        <DataTemplate x:Key="UserMessageTemplate">
            <Border Background="{StaticResource AccentBrush}"
                    CornerRadius="12"
                    Padding="12,10"
                    Margin="40,5,5,5"
                    HorizontalAlignment="Right"
                    MaxWidth="350">
                <TextBlock Text="{Binding Text}"
                           Foreground="White"
                           TextWrapping="Wrap"
                           FontSize="14"/>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="AiMessageTemplate">
            <Border Background="{StaticResource CardBrush}"
                    CornerRadius="12"
                    Padding="12,10"
                    Margin="5,5,40,5"
                    HorizontalAlignment="Left"
                    MaxWidth="350">
                <TextBlock Text="{Binding Text}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextWrapping="Wrap"
                           FontSize="14"/>
            </Border>
        </DataTemplate>

        <Storyboard x:Key="SlideInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="420" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="SlideOutAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="420" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="RootGrid"
          PreviewMouseDown="RootGrid_PreviewMouseDown">
        <!-- 1. Кнопка-триггер -->
        <Button x:Name="ToggleButton"
                Content="🤖"
                Width="50"
                Height="50"
                FontSize="22"
                Background="{StaticResource WarningBrush}"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Click="ToggleButton_Click"
                ToolTip="Открыть AI-помощник">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Margin" Value="0,0,-25,0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="25,0,0,25"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- 2. Затемнение фона (под панелью) -->
        <Border x:Name="OverlayBorder"
                Background="#40000000"
                Visibility="Collapsed"/>

        <!-- 3. Панель чата (сверху) -->
        <Border x:Name="ChatPanel"
                Width="420"
                Background="{StaticResource BackgroundBrush}"
                BorderBrush="#E0E0E0"
                BorderThickness="1,0,0,0"
                HorizontalAlignment="Right"
                Visibility="Collapsed"
                RenderTransformOrigin="0,0">
            <Border.RenderTransform>
                <TranslateTransform X="420"/>
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <Border Background="{StaticResource WarningBrush}" Padding="20,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="🤖 AI-помощник"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                            <TextBlock Text="Генерация вопросов через GigaChat"
                                       FontSize="11"
                                       Foreground="#DDFFFFFF"
                                       Margin="0,3,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="✕"
                                Width="32"
                                Height="32"
                                FontSize="16"
                                Background="#33FFFFFF"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="CloseButton_Click"
                                ToolTip="Закрыть"/>
                    </Grid>
                </Border>

                <!-- Сообщения -->
                <ScrollViewer Grid.Row="1"
                              x:Name="MessagesScrollViewer"
                              Margin="10,10,10,5"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="MessagesItemsControl">
                        <ItemsControl.ItemTemplateSelector>
                            <local:ChatMessageTemplateSelector/>
                        </ItemsControl.ItemTemplateSelector>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Быстрые действия -->
                <Border Grid.Row="2"
                        Background="#F8F9FA"
                        Padding="10,8"
                        Margin="5,5">
                    <StackPanel>
                        <TextBlock Text="Быстрые действия:"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,5"/>
                        <WrapPanel>
                            <Button Content="5 вопросов"
                                    FontSize="11"
                                    Padding="8,4"
                                    Margin="2"
                                    Background="White"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1"
                                    Foreground="{StaticResource AccentBrush}"
                                    Click="QuickAction_Click"
                                    Tag="5"/>
                            <Button Content="10 вопросов"
                                    FontSize="11"
                                    Padding="8,4"
                                    Margin="2"
                                    Background="White"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1"
                                    Foreground="{StaticResource AccentBrush}"
                                    Click="QuickAction_Click"
                                    Tag="10"/>
                            <Button Content="Тест по теме"
                                    FontSize="11"
                                    Padding="8,4"
                                    Margin="2"
                                    Background="White"
                                    BorderBrush="{StaticResource WarningBrush}"
                                    BorderThickness="1"
                                    Foreground="{StaticResource WarningBrush}"
                                    Click="QuickTestAction_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Поле ввода -->
                <Border Grid.Row="3"
                        Background="{StaticResource CardBrush}"
                        Padding="10"
                        BorderThickness="0,1,0,0"
                        BorderBrush="#E0E0E0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="MessageInput"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Padding="12,8"
                                 FontSize="14"
                                 AcceptsReturn="False"
                                 KeyDown="MessageInput_KeyDown"
                                 GotFocus="MessageInput_GotFocus"
                                 LostFocus="MessageInput_LostFocus"
                                 Text="О чём сгенерировать вопросы?"/>

                        <Button Grid.Column="1"
                                x:Name="SendButton"
                                Content="➤"
                                Width="42"
                                Height="42"
                                FontSize="18"
                                Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="SendButton_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
