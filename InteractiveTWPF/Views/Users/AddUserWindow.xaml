<Window x:Class="InteractiveTWPF.AddUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Добавление пользователя"
        Height="560" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="../../Resources/Colors.xaml"/>
            <ResourceDictionary Source="../../Resources/Styles.xaml"/>
        </ResourceDictionary.MergedDictionaries>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Новый пользователь"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="ФИО"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="FullNameTextBox"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Margin="0,0,0,15"/>

            <TextBlock Text="Логин"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="LoginTextBox"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Margin="0,0,0,15"/>

            <TextBlock Text="Пароль"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox"
                         Background="{StaticResource CardBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource TextSecondaryBrush}"
                         Padding="12,8"
                         FontSize="14"
                         Margin="0,0,0,15"/>

            <TextBlock Text="Роль"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,5"/>
            <ComboBox x:Name="RoleComboBox"
                      SelectedIndex="3"
                      Margin="0,0,0,15"
                      Padding="12,8"
                      FontSize="14"
                      SelectionChanged="RoleComboBox_SelectionChanged">
                <ComboBoxItem Content="Администратор" Tag="0"/>
                <ComboBoxItem Content="Завуч" Tag="1"/>
                <ComboBoxItem Content="Учитель" Tag="2"/>
                <ComboBoxItem Content="Ученик" Tag="3"/>
            </ComboBox>

            <StackPanel x:Name="ClassSelectionPanel"
                        Visibility="Collapsed"
                        Margin="0,0,0,15">
                <TextBlock Text="Класс"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <ComboBox x:Name="ClassComboBox"
                              Margin="0,0,5,0"
                              Padding="12,8"
                              FontSize="14"
                              Width="250"
                              DisplayMemberPath="Name"
                              ToolTip="Выберите класс для ученика"/>
                    <Button Content="+ Класс"
                            Width="80"
                            Padding="5"
                            FontSize="12"
                            Background="{StaticResource AccentBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            Click="AddClassButton_Click"/>
                </StackPanel>
            </StackPanel>

            <CheckBox x:Name="IsActiveCheckBox"
                      Content="Активен"
                      IsChecked="True"
                      FontSize="14"
                      Margin="0,0,0,10"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Создать"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="130"
                    Margin="0,0,10,0"
                    Click="CreateButton_Click"/>
            <Button Content="Отмена"
                    Width="130"
                    Background="{StaticResource TextSecondaryBrush}"
                    Foreground="White"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
